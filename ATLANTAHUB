end)

-- Timer ESP update + Auto Grab loop
RunService.Heartbeat:Connect(function()

	-- Timer ESP: find BaseTimer or Timer value and display it
	if timerESP then
		local timerObj = workspace:FindFirstChild("BaseTimer") or workspace:FindFirstChild("Timer")
		if timerObj then
			timerESPLabel.Adornee = timerObj
			local val = timerObj:FindFirstChildWhichIsA("NumberValue") or timerObj:FindFirstChildWhichIsA("IntValue") or timerObj:FindFirstChildWhichIsA("StringValue")
			if val then
				espTextLabel.Text = "⏱ " .. tostring(math.floor(tonumber(val.Value) or 0)) .. "s"
			elseif timerObj:IsA("NumberValue") or timerObj:IsA("IntValue") then
				espTextLabel.Text = "⏱ " .. tostring(math.floor(timerObj.Value)) .. "s"
			end
		end
	end

	-- Auto grab: find nearby ProximityPrompt and trigger it
	if autoGrab and rootPart then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("ProximityPrompt") then
				local part = obj.Parent
				if part and part:IsA("BasePart") then
					local dist = (rootPart.Position - part.Position).Magnitude
					if dist <= AUTO_GRAB_RANGE then
						fireproximityprompt(obj)
					end
				end
			end
		end
	end
end)
