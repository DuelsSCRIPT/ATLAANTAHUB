-- =====================
--   DRAGGING (main)
-- =====================

local dragging = false
local dragStart = nil
local startPos = nil

headerBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (
		input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch
	) then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

-- =====================
--   DRAGGING (mini pill)
-- =====================

local miniDragging = false
local miniDragStart = nil
local miniStartPos = nil
local miniDragMoved = false

miniBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		miniDragging = true
		miniDragMoved = false
		miniDragStart = input.Position
		miniStartPos = miniBtn.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if miniDragging and (
		input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch
	) then
		local delta = input.Position - miniDragStart
		if math.abs(delta.X) > 4 or math.abs(delta.Y) > 4 then
			miniDragMoved = true
		end
		miniBtn.Position = UDim2.new(
			miniStartPos.X.Scale, miniStartPos.X.Offset + delta.X,
			miniStartPos.Y.Scale, miniStartPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		miniDragging = false
	end
end)

-- =====================
--   OPEN / CLOSE LOGIC
-- =====================

local isAnimating = false

local function closeGui()
	if isAnimating then return end
	isAnimating = true

	-- Fade out main frame
	TweenService:Create(mainFrame, quickFade, {BackgroundTransparency = 1}):Play()
	TweenService:Create(mainStroke, quickFade, {Transparency = 1}):Play()
	TweenService:Create(headerBar, quickFade, {BackgroundTransparency = 1}):Play()
	TweenService:Create(hubTitle, quickFade, {TextTransparency = 1}):Play()
	TweenService:Create(contentLabel, quickFade, {TextTransparency = 1}):Play()
	TweenService:Create(divider, quickFade, {BackgroundTransparency = 1}):Play()

	task.wait(0.35)
	mainFrame.Visible = false

	-- Reset transparencies for when it reopens
	mainFrame.BackgroundTransparency = 0
	mainStroke.Transparency = 0
	headerBar.BackgroundTransparency = 0
	hubTitle.TextTransparency = 0
	contentLabel.TextTransparency = 0
	divider.BackgroundTransparency = 0

	miniBtn.Visible = true
	isAnimating = false
end

local function openGui()
	if isAnimating then return end
	if miniDragMoved then return end -- dont open if user was dragging
	isAnimating = true

	miniBtn.Visible = false
	mainFrame.Visible = true

	-- Start transparent then fade in
	mainFrame.BackgroundTransparency = 1
	mainStroke.Transparency = 1
	headerBar.BackgroundTransparency = 1
	hubTitle.TextTransparency = 1
	contentLabel.TextTransparency = 1
	divider.BackgroundTransparency = 1

	TweenService:Create(mainFrame, quickFade, {BackgroundTransparency = 0}):Play()
	TweenService:Create(mainStroke, quickFade, {Transparency = 0}):Play()
	TweenService:Create(headerBar, quickFade, {BackgroundTransparency = 0}):Play()
	TweenService:Create(hubTitle, quickFade, {TextTransparency = 0}):Play()
	TweenService:Create(contentLabel, quickFade, {TextTransparency = 0}):Play()
	TweenService:Create(divider, quickFade, {BackgroundTransparency = 0}):Play()

	task.wait(0.35)
	isAnimating = false
end

closeBtn.MouseButton1Click:Connect(closeGui)
miniBtn.MouseButton1Click:Connect(openGui)
